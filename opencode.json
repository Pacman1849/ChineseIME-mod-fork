{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Cherry-Nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cherry-Nvidia",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY_NVIDIA}",
        "baseURL": "https://integrate.api.nvidia.com/v1"
      },
      "models": {
        "minimaxai/minimax-m2.7": {
          "name": "minimaxai/minimax-m2.7",
          "reasoning": true
        }
      }
    }
  }
}