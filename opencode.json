{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "Cherry-OpenRouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cherry-OpenRouter",
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY_OPENROUTER}",
        "baseURL": "https://openrouter.ai/api/v1"
      },
      "models": {
        "deepseek/deepseek-chat": {
          "name": "DeepSeek: V3",
